{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "UserResiliencePolicySettings": {
        "MaxRetryAttempts": 2,
        "TimeoutInMilliseconds": 975,
        "InnerTimeoutInMilliseconds": 275,
        "Delay": 0.050,
        "FailureRatio": 0.9,
        "SampleDuration": 15,
        "MinimumThroughput": 20,
        "BreakDuration": 1
    },
    "AllowedHosts": "*"
}
